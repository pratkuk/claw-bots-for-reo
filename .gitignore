# ─── Environment ──────────────────────────────────────────
# NEVER commit .env — it holds API keys and secrets.
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ─── Node (for workspace/projects/hello-test Vite app) ────
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# ─── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
.AppleDouble
.LSOverride

# ─── Editors ──────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ─── Pinata / OpenClaw runtime state ──────────────────────
# USER.md is filled in at runtime by the agent as it learns about the user.
# We ship it blank in the template; if it's edited locally, do not commit.
# (Remove the next line if you want to intentionally ship learned USER.md content.)
# workspace/USER.md
