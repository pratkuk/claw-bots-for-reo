# =============================================================
# Reo x Pinata Agent Template — Environment Variables (template)
# =============================================================
# This file is COMMITTED to git and holds placeholders only.
# For real values: copy to .env and fill in locally.
#   cp .env.example .env
# .env is gitignored and must never be committed.
# =============================================================

# ─── Reo API (required) ──────────────────────────────────────
# Request your key via contact@reo.dev.
# Docs: https://developers.reo.dev/
# The Reo API authenticates every request using an `x-api-key` header.
# Paste your key AFTER the equals sign on the REO_API_KEY line below —
# not into this comment block (this is documentation only).
REO_API_BASE_URL=https://integration.reo.dev
REO_INGEST_BASE_URL=https://ingest.reo.dev
REO_API_KEY=replace_with_reo_api_key

# Reo tenant / workspace ID.
# Public docs do NOT require this — auth is scoped by API key alone.
# Leave blank unless you've been told otherwise by Reo.
# The smoke test will surface a real error if it turns out to be needed.
REO_TENANT_ID=

# ─── Pinata / OpenClaw (required to deploy & test end-to-end) ─
# Promo code from Drew at Pinata. Used once during deploy on
# agents.pinata.cloud to spin up the test template.
PINATA_PROMO_CODE=replace_with_pinata_promo_code

# ─── Slack (used by Pinata's bootstrap pairing flow) ─────────
# Note: the actual Slack OAuth token is handled by Pinata when you
# pair the workspace. We only need to know WHICH workspace + channel
# to target during testing, so we can verify the digest arrives.
SLACK_WORKSPACE=replace_with_slack_workspace_name_or_url
SLACK_TEST_CHANNEL=#reo-intel-test

# ─── Internal MCP auth token (generated, not user-supplied) ──
# Shared secret between the OpenClaw agent and the local MCP server,
# used over Pinata's port-forwarded route. Must be present but the
# VALUE can be any long random string. For local dev, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REO_MCP_INTERNAL_TOKEN=replace_with_random_32_byte_token

# ─── Test data (not secret — safe to edit freely) ────────────
# Comma-separated Web3 org domains to exercise the Reo API with
# during the smoke test. Pick orgs you know exist in your Reo account.
# Example: uniswap.org,alchemy.com,chainlinklabs.com
REO_TEST_DOMAINS=

# ACCOUNT-type segment ID containing your Web3 target accounts.
# Find it in the Reo dashboard URL: .../accounts?segId=<THIS>
# In production, the agent asks the user to pick a segment during bootstrap
# and stores the ID in workspace/USER.md. For local development we hard-code.
REO_TEST_SEGMENT_ID=
